{
  "expo": {
    "name": "Study Monitor",
    "slug": "study-monitor",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "studymonitor",
    "android": {
      "package": "com.studymonitor",
      "adaptiveIcon": { "backgroundColor": "#f0b429" },
      "permissions": [
        "RECORD_AUDIO",
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE",
        "BIND_DEVICE_ADMIN",
        "BIND_VPN_SERVICE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "VIBRATE",
        "USE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "PACKAGE_USAGE_STATS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ]
  }
}
